{
  "name": "@fleetia/lagrange",
  "version": "0.0.0",
  "description": "Editorial React design system for dense, precise interfaces.",
  "type": "module",
  "license": "AGPL-3.0-only",
  "author": "ansible-starlight-space",
  "homepage": "https://github.com/fleetia/lagrange#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fleetia/lagrange.git"
  },
  "bugs": {
    "url": "https://github.com/fleetia/lagrange/issues"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "vite build",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm verify:react-18 && pnpm consumer:build && pnpm storybook:build",
    "consumer:build": "pnpm --filter @fleetia/lagrange-consumer build",
    "dev": "storybook dev -p 6006",
    "lint": "eslint .",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test": "vitest run",
    "test:visual": "playwright test",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify:react-18": "node scripts/verify-react-18.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "peerDependencies": {
    "react": ">=18.2.0 <20",
    "react-dom": ">=18.2.0 <20"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/css": "^1.21.1",
    "@vanilla-extract/vite-plugin": "^5.2.4",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "4.1.9"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.14.0"
  }
}
